{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "sync-server": "tsx server/sync-server.ts",
    "build": "vite build",
    "build:exe-static": "vite build --outDir exe-public",
    "build:desktop-cjs": "esbuild server/desktop.ts --bundle --platform=node --format=cjs --outfile=desktop.cjs",
    "build:win": "npm run build:exe-static && npm run build:desktop-cjs && npx pkg . --targets node18-win-x64 --output release/particle-desktop.exe",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "bin": "desktop.cjs",
  "pkg": {
    "assets": [
      "exe-public/**/*"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "vite": "^6.2.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
